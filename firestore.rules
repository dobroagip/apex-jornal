rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['user', 'admin'])
    //   - favorites: list (optional) - Array of article IDs
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "milleniumtraffy@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             ( !('favorites' in data) || data.favorites is list );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can only read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Creation: User can create their own profile. Default role must be 'user' unless admin.
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      
      // Update: User can update their own profile, but cannot change their role unless admin.
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin()) &&
                      request.resource.data.createdAt == resource.data.createdAt;
      
      allow delete: if isAdmin();
    }

    match /articles/{articleId} {
      // Public can read published articles. Admins can read all.
      allow read: if resource.data.published == true || isAdmin();
      
      // Only admins can create or update articles.
      allow create, update: if isAdmin() && 
                             request.resource.data.authorId == request.auth.uid;
      
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
